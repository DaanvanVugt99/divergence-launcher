{
  "name": "divergence-launcher",
  "productName": "Divergence Launcher",
  "version": "0.1.0",
  "description": "Optional desktop launcher for Pokemon Emerald Rogue: Divergence.",
  "main": ".vite/build/main.js",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "prepare:package-resources": "node scripts/prepare-native-xdelta.mjs",
    "prepackage": "npm run prepare:package-resources",
    "prepackage:mac": "npm run prepare:package-resources",
    "premake": "npm run prepare:package-resources",
    "premake:mac": "npm run prepare:package-resources",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "package:mac": "electron-forge package --platform=darwin --arch=arm64",
    "make": "electron-forge make",
    "make:mac": "electron-forge make --platform=darwin --arch=arm64",
    "zip:mac": "node scripts/create-macos-zip.mjs",
    "verify:mac-artifact": "node scripts/verify-macos-artifact.mjs",
    "release:check": "npm run typecheck && npm test",
    "release:mac": "npm run release:check && npm run package:mac && npm run zip:mac && npm run verify:mac-artifact",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:patch": "node scripts/generate-patch.mjs"
  },
  "keywords": [
    "electron",
    "pokemon",
    "launcher",
    "mgba",
    "xdelta"
  ],
  "author": "GEEF",
  "license": "MIT",
  "dependencies": {
    "@chainsafe/xdelta3-node": "^1.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^1.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
